#########################
# Application
#########################
PORT=3001

#########################
# Database
#########################
DATABASE_URL="mysql://root:Password1@localhost:3306/probayo"

#########################
# Auth / JWT
#########################
JWT_SECRET="your-super-secret-jwt-key-change-in-production-12345678"
JWT_EXPIRATION="24h"

#########################
# Storage
#########################
# Use 'local' or 's3'
STORAGE_TYPE=local

# S3 settings (used when STORAGE_TYPE=s3)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_key
AWS_SECRET_ACCESS_KEY=your_secret
AWS_S3_BUCKET=probayo-attachments

#########################
# Redis / Message Queue (BullMQ)
#########################
# URL form (optional): redis://[:password@]host:port/db
REDIS_URL=redis://:redispass@127.0.0.1:6379/0

# Individual Redis fields (used if REDIS_URL is not provided)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_USERNAME=redis
REDIS_PASSWORD=redispass
REDIS_DB=0

# BullMQ / Queue settings
BULLMQ_PREFIX=probayo

# ─── Email Provider API Key (Replaced Brevo with Resend) ───────
# Set your Resend API key here. Previously this project used BREVO_API_KEY.
RESEND_API_KEY="rsk_your_resend_api_key_here"
EMAIL_FROM_ADDRESS="it-support@yourcompany.com"
EMAIL_FROM_NAME="IT Helpdesk"